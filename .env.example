# ==================================================================
# AeganMediaMontage - Environment Variables
# ==================================================================
# Copy to .env and fill in your values.
# Add the same keys as GitHub Environment secrets (development).
#
# This application uses ONLY Google AI services.
# A single GOOGLE_API_KEY unlocks all AI features.
# ==================================================================

# ------------------------------------------------------------------
# GOOGLE AI (single key — powers everything)
# ------------------------------------------------------------------
# Get your free API key at: https://aistudio.google.com/apikey
#
# Enable these APIs in your Google Cloud project:
#   1. Generative Language API  (Gemini — script, scenes, transcription)
#   2. Cloud Text-to-Speech API (narration voice generation)
#   3. Imagen API               (AI image generation — via Gemini endpoint)
#
GOOGLE_API_KEY=

# ==================================================================
# Application / Auth
# ==================================================================
APP_NAME=AeganMediaMontage
HOST=0.0.0.0
PORT=41006
JWT_SECRET=
JWT_EXP_MINUTES=1440

# MongoDB Atlas
MONGODB_URI=
MONGODB_DB=aeganmediamontage

# Video retention and storage
VIDEOS_ROOT=/var/aeganmediamontage/videos
VIDEO_RETENTION_HOURS=48

# Bootstrap
INIT_DB_ON_BOOT=false
INIT_SEED_USERS=true
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=
SEED_MANAGER_EMAIL=manager@yourdomain.com
SEED_MANAGER_PASSWORD=
SEED_USER_EMAIL=user@yourdomain.com
SEED_USER_PASSWORD=User@2026

# Credits & Free Tier (users must be admin-approved first)
CREDIT_COST_PER_RUN=1
FREE_TIER_MAX_RUNS=1
FREE_TIER_MAX_DURATION=10

# ------------------------------------------------------------------
# Pipeline Worker
# ------------------------------------------------------------------
PIPELINE_RUN_COMMAND=python -m webapp.pipeline_runner --pipeline {pipeline} --project {project_id} --prompt-file {prompt_file}
WORKER_POLL_SECONDS=5
WORKER_TIMEOUT_SECONDS=10800
