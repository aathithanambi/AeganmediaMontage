# ==================================================================
# OpenMontage - Environment Variables
# ==================================================================
# Copy to .env and fill in your keys.
# Add the same keys as GitHub Environment secrets (development).
#
# LEGEND:
#   [FREE]  = Free API key, no credit card required
#   [PAID]  = Requires billing / credits
#   [LOCAL] = Runs locally, no API key needed
# ==================================================================

# ------------------------------------------------------------------
# 1. STOCK MEDIA (FREE — get these first, unlocks all pipelines)
# ------------------------------------------------------------------
PEXELS_API_KEY=              # [FREE] Stock photos + video   https://www.pexels.com/api/
PIXABAY_API_KEY=             # [FREE] Stock photos + video   https://pixabay.com/api/docs/

# ------------------------------------------------------------------
# 2. fal.ai (ONE KEY — unlocks the most tools)
# ------------------------------------------------------------------
FAL_KEY=                     # [PAID] FLUX images, Veo video, Kling video, MiniMax video,
                             #        Recraft images, CogVideo, Hunyuan video
                             #        https://fal.ai/dashboard/keys

# ------------------------------------------------------------------
# 3. VOICE / TTS
# ------------------------------------------------------------------
# Piper TTS is LOCAL and FREE — no key needed (installed in Docker image)
ELEVENLABS_API_KEY=          # [PAID] Best TTS quality, music gen, sound effects
                             #        https://elevenlabs.io/
GOOGLE_API_KEY=              # [FREE tier] Google Cloud TTS (700+ voices, 50+ languages)
                             #             + Google Imagen image generation
                             #             https://aistudio.google.com/apikey
OPENAI_API_KEY=              # [PAID] OpenAI TTS fallback + DALL-E image generation
                             #        https://platform.openai.com/api-keys

# ------------------------------------------------------------------
# 4. MUSIC GENERATION
# ------------------------------------------------------------------
SUNO_API_KEY=                # [PAID] Suno AI music (full songs, instrumentals, any genre)
FREESOUND_API_KEY=           # [FREE] Freesound.org music/SFX search
                             #        https://freesound.org/apiv2/apply

# ------------------------------------------------------------------
# 5. VIDEO GENERATION
# ------------------------------------------------------------------
HEYGEN_API_KEY=              # [PAID] HeyGen avatars + VEO/Sora/Runway/Kling/Seedance
                             #        via HeyGen gateway
RUNWAY_API_KEY=              # [PAID] Runway Gen-4 direct API (alternative to fal.ai)
XAI_API_KEY=                 # [PAID] Grok image gen/editing + Grok video generation
                             #        https://console.x.ai/

# Local video generation (requires GPU + diffusers, not used in Docker)
# VIDEO_GEN_LOCAL_ENABLED=   # Set to "true" for local video gen
# VIDEO_GEN_LOCAL_MODEL=     # wan2.1-1.3b | wan2.1-14b | hunyuan-1.5 | ltx2-local | cogvideo-5b
# MODAL_LTX2_ENDPOINT_URL=  # Self-hosted LTX-2 endpoint on Modal

# ------------------------------------------------------------------
# 6. ANALYSIS / TRANSCRIPTION
# ------------------------------------------------------------------
HF_TOKEN=                    # [FREE] HuggingFace token — speaker diarization in transcriber
                             #        https://huggingface.co/settings/tokens

# ------------------------------------------------------------------
# 7. AVATAR (local installs, advanced)
# ------------------------------------------------------------------
# WAV2LIP_PATH=              # Path to cloned Wav2Lip repo (for lip sync)
# SADTALKER_PATH=            # Path to cloned SadTalker repo (for talking head avatars)

# ==================================================================
# AeganMediaMontage Website / Auth
# ==================================================================
APP_NAME=AeganMediaMontage
HOST=0.0.0.0
PORT=41006
JWT_SECRET=
JWT_EXP_MINUTES=1440

# MongoDB Atlas
MONGODB_URI=
MONGODB_DB=aeganmediamontage

# Video retention and storage
VIDEOS_ROOT=/var/aeganmediamontage/videos
VIDEO_RETENTION_HOURS=48

# Bootstrap
INIT_DB_ON_BOOT=false
INIT_SEED_USERS=true
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=
SEED_MANAGER_EMAIL=manager@yourdomain.com
SEED_MANAGER_PASSWORD=
SEED_USER_EMAIL=user@yourdomain.com
SEED_USER_PASSWORD=User@2026

# Credits
CREDIT_COST_PER_RUN=1

# ------------------------------------------------------------------
# Pipeline Worker
# ------------------------------------------------------------------
# Default uses built-in runner (TTS + stock images + FFmpeg/Remotion).
# Override to use an external AI agent for full multi-stage production.
PIPELINE_RUN_COMMAND=python -m webapp.pipeline_runner --pipeline {pipeline} --project {project_id} --prompt-file {prompt_file}
WORKER_POLL_SECONDS=5
WORKER_TIMEOUT_SECONDS=10800
