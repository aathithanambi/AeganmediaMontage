# ==================================================================
# AeganMediaMontage - Environment Variables
# ==================================================================
# Copy to .env and fill in your values.
# Add the same keys as GitHub Environment secrets (development).
#
# This application uses ONLY Google AI services.
# A single GOOGLE_API_KEY unlocks all AI features.
# ==================================================================

# ------------------------------------------------------------------
# GOOGLE AI (single key — powers everything)
# ------------------------------------------------------------------
# Get your free API key at: https://aistudio.google.com/apikey
#
# Enable these APIs in your Google Cloud project:
#   1. Generative Language API  (Gemini — script, scenes, transcription)
#   2. Cloud Text-to-Speech API (narration voice generation)
#   3. Imagen API               (AI image generation — via Gemini endpoint)
#
GOOGLE_API_KEY=

# Image generation: gemini = native Gemini image (Nano Banana family, default) | imagen | auto (Gemini then Imagen fallback)
# IMAGE_BACKEND=gemini
# Comma-separated model fallbacks for native image (see Gemini API release notes for current IDs)
# GEMINI_NATIVE_IMAGE_MODELS=gemini-2.0-flash-preview-image-generation,gemini-2.5-flash-image-preview
# Optional short-form / feed-style look (adds prompt bias)
# IMAGE_STYLE_PROFILE=meta

# Character lock: reuse extracted cast/outfit colors when transcript fingerprint matches (saves one Gemini call per re-run)
# CHARACTER_CACHE=1
# IMAGE_PROMPT_CACHE=1

# ==================================================================
# Application / Auth
# ==================================================================
APP_NAME=AeganMediaMontage
HOST=0.0.0.0
PORT=41006
JWT_SECRET=
JWT_EXP_MINUTES=1440

# MongoDB Atlas
MONGODB_URI=
MONGODB_DB=aeganmediamontage

# Video retention and storage
VIDEOS_ROOT=/var/aeganmediamontage/videos
VIDEO_RETENTION_HOURS=48

# Bootstrap
INIT_DB_ON_BOOT=false
INIT_SEED_USERS=true
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=
SEED_MANAGER_EMAIL=manager@yourdomain.com
SEED_MANAGER_PASSWORD=
SEED_USER_EMAIL=user@yourdomain.com
SEED_USER_PASSWORD=User@2026

# Credits & Free Tier (users must be admin-approved first)
CREDIT_COST_PER_RUN=1
FREE_TIER_MAX_RUNS=1
FREE_TIER_MAX_DURATION=10

# ------------------------------------------------------------------
# Pipeline Worker
# ------------------------------------------------------------------
PIPELINE_RUN_COMMAND=python -m webapp.pipeline_runner --pipeline {pipeline} --project {project_id} --prompt-file {prompt_file}
WORKER_POLL_SECONDS=5
WORKER_TIMEOUT_SECONDS=21600

# Max scenes per video (higher for longer videos, e.g. 200 for 20-min audio)
# PIPELINE_MAX_SCENES=120

# ------------------------------------------------------------------
# Google Speech-to-Text API (word-level timestamp transcription)
# ------------------------------------------------------------------
# The same GOOGLE_API_KEY above is used for authentication.
# Enable "Cloud Speech-to-Text API" in your Google Cloud project:
#   https://console.cloud.google.com/apis/library/speech.googleapis.com
#
# Default language code for Tamil audio transcription:
# SPEECH_LANGUAGE_CODE=ta-IN
#
# Set to 0 to force Gemini timestamp estimation (bypass Speech API):
# USE_GOOGLE_SPEECH_API=1

# ------------------------------------------------------------------
# Agent Checkpoints (pipeline phase resumption)
# ------------------------------------------------------------------
# When CHECKPOINT_RESUME=1, completed pipeline phases are reloaded
# from JSON files instead of re-running. Saves API cost on retries.
# Checkpoints are stored at: projects/<id>/checkpoints/<phase>.json
#
# Phases: transcript_v1 | translation_v1 | scenes_v1 | images_v1
#
# CHECKPOINT_RESUME=0
